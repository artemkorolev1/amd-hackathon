# amd-hackathon-submit — parallel submission CPU container
# Build: docker buildx build --platform linux/amd64 -t ghcr.io/artemkorolev1/amd-hackathon-submit:cpu --load -f Dockerfile.cpu .
#
# CPU submission variant for AMD ACT II Hackathon.
# Grader: 2 vCPU / 4 GB RAM — NO GPU.
# Uses staging/entrypoint.py (parallel pool system).
# CPU-safe defaults: N_GPU_LAYERS=0, N_THREADS=2, N_CTX=2048.

FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_BREAK_SYSTEM_PACKAGES=1

WORKDIR /

# Runtime libs for llama-cpp-python CPU build
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps
COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt \
    && apt-get purge -y --auto-remove build-essential curl \
    && rm -rf /var/lib/apt/lists/* \
    && find /usr/local/lib -name '__pycache__' -exec rm -rf {} + 2>/dev/null || true

# Copy agent module (plug-and-play Pipeline class — untouchable golden rule)
COPY agent/ /agent/

# Copy staging module (parallel pool system — entrypoint lives here)
COPY staging/ /staging/

# Copy fact database (FTS5 knowledge base for deterministic solver)
COPY data/facts/ /data/facts/

# Copy models (GGUF files — explicit for layer caching, instruct only for CPU)
COPY models/qwen2.5-1.5b-instruct-q4_k_m.gguf /models/qwen2.5-1.5b-instruct-q4_k_m.gguf
COPY models/qwen2.5-coder-1.5b-instruct-q4_k_m.gguf /models/qwen2.5-coder-1.5b-instruct-q4_k_m.gguf
COPY models/gemma-3-1b-it-Q4_K_M.gguf /models/gemma-3-1b-it-Q4_K_M.gguf

# Ensure grader I/O paths
RUN mkdir -p /input /output

ENV PYTHONPATH=/ \
    MODEL_PATH=/models/qwen2.5-1.5b-instruct-q4_k_m.gguf \
    N_GPU_LAYERS=0 \
    N_THREADS=2 \
    N_CTX=2048

ENTRYPOINT ["python3", "-u", "-m", "staging.entrypoint"]
