"""ReadyPool — Manages 4 parallel worker processes.

Architecture:
  - 4 worker processes (1 FW + 1 Local + 2 Det by default)
  - Shared multiprocessing.Queue for task dispatch (pull model)
  - Shared multiprocessing.Queue for result collection
  - Per-worker busy flags via multiprocessing.Value
  - Main loop: dispatch → collect → judge → repeat
  - Deadline adaptation: full 5-vote → reduced → fire-and-forget
"""

import logging
import multiprocessing
import signal
import time
from typing import Optional

from staging.ready_config import ReadyConfig
from staging.ready_queue import ReadyQueue, ReadyTask
from staging.ready_judge import ReadyJudge

# Worker factory registry
_WORKER_REGISTRY: dict[str, type] = {}

logger = logging.getLogger(__name__)


def register_worker_type(worker_type: str, cls: type) -> None:
    """Register a worker class for a type name."""
    _WORKER_REGISTRY[worker_type] = cls


class ReadyPool:
    """Orchestrates 4 parallel workers, collects results, coordinates judge."""

    def __init__(self, config: ReadyConfig):
        self.config = config
        self._category_queues: dict[str, multiprocessing.Queue] = {}
        self._results_queue: Optional[multiprocessing.Queue] = None
        self._processes: list[multiprocessing.Process] = []
        self._busy_flags: list[multiprocessing.Value] = []
        self._ready_flags: list[multiprocessing.Value] = []
        self._worker_ids: list[str] = []
        self._worker_task_queues: list[multiprocessing.Queue] = []
        self._started = False
        self._running = multiprocessing.Event()
        self._pending_dispatched: set[str] = set()  # task_ids that have been dispatched

    # ── Lifecycle ──

    def start(self, queue: ReadyQueue) -> None:
        """Create shared queues, spawn worker processes.

        Workers are spawned first, then we wait for all to signal ready.
        Tasks are NOT enqueued here — they're split per-worker in dispatch_loop
        after all workers are ready, preventing fast workers from starving slow ones.
        """
        if self._started:
            logger.warning("Pool already started")
            return

        self._results_queue = multiprocessing.Queue()
        self._running.set()

        # ── Create per-category queues for all 8 categories ──
        self._category_queues.clear()
        for cat in ["code_debug", "code_gen", "factual", "logic", "math", "ner", "sentiment", "summarization"]:
            self._category_queues[cat] = multiprocessing.Queue()

        # ── Spawn workers ──
        workers_to_start = self._build_worker_plan()

        for wid, wtype, worker_cls, index in workers_to_start:
            busy_flag = multiprocessing.Value('b', 0)  # 0 = not busy
            whitelist = self._build_whitelist(wtype)
            ready_flag = multiprocessing.Value('b', 0)  # 0 = not ready

            worker = worker_cls(
                worker_id=wid,
                worker_type=wtype,
                config=self.config,
                task_queue=multiprocessing.Queue(),  # Dummy fallback; workers use task_queues
                results_queue=self._results_queue,
                busy_flag=busy_flag,
                worker_index=index,
                task_queues=self._category_queues,
                category_whitelist=whitelist,
                ready_flag=ready_flag,
            )
            self._ready_flags.append(ready_flag)
            self._worker_task_queues.append(worker.task_queue)

            p = multiprocessing.Process(
                target=worker.run,
                name=wid,
                daemon=True,
            )
            p.start()
            self._processes.append(p)
            self._busy_flags.append(busy_flag)
            self._worker_ids.append(wid)

            logger.info("[pool] Started %s (type=%s, pid=%d, whitelist=%s)",
                        wid, wtype, p.pid, whitelist)

        self._started = True
        logger.info("[pool] All %d workers started", len(self._processes))

        # Wait for ALL workers to signal ready before enqueuing tasks.
        # This prevents fast-init workers (det) from consuming all tasks
        # before slow-init workers (local LLM model load) are ready.
        if self._ready_flags:
            logger.info("[pool] Waiting for %d workers to signal ready...", len(self._ready_flags))
            deadline = time.monotonic() + 30.0
            for i, flag in enumerate(self._ready_flags):
                while time.monotonic() < deadline and flag.value == 0:
                    time.sleep(0.1)
            logger.info("[pool] All workers ready — enqueuing tasks")

        # Distribute tasks per-worker to prevent fast workers from starving slow ones.
        # Each worker gets its own private queue with a share of the tasks.
        all_tasks: list[ReadyTask] = []
        while not queue.empty:
            task = queue.dequeue_any(preferred_categories=[])
            if task is None:
                break
            all_tasks.append(task)
            self._pending_dispatched.add(task.task_id)

        if all_tasks and self._processes:
            n_workers = len(self._processes)
            chunks = [[] for _ in range(n_workers)]
            for i, task in enumerate(all_tasks):
                chunks[i % n_workers].append(task)
            for i, chunk in enumerate(chunks):
                for task in chunk:
                    if i < len(self._worker_task_queues):
                        self._worker_task_queues[i].put_nowait(task)
            logger.info("[pool] Distributed %d tasks across %d workers", len(all_tasks), n_workers)

    def dispatch_loop(self, queue: ReadyQueue, judge: ReadyJudge, deadline: float) -> None:
        """Main dispatch loop: ingest results → judge → check deadline.

        Args:
            queue: The original ReadyQueue (for task lookup)
            judge: The ReadyJudge instance
            deadline: Absolute time.monotonic() deadline
        """
        if not self._started:
            self.start(queue)

        # Also enqueue any remaining tasks that weren't in the initial batch
        self._enqueue_remaining(queue)

        total_tasks = len(self._pending_dispatched)
        judged_count = 0
        last_log = 0.0

        while self._running.is_set():
            now = time.monotonic()
            remaining = deadline - now

            # ── Health check: detect crashed workers (R3) ──
            self._check_worker_health()

            # Log progress periodically
            if now - last_log >= 10.0:
                still_pending = total_tasks - judge.total_judged
                busy_count = sum(f.value for f in self._busy_flags)
                logger.info(
                    "[pool] Progress: %d/%d judged, %d pending, %d busy, %.0fs remaining",
                    judge.total_judged, total_tasks, still_pending, busy_count, remaining
                )
                last_log = now

            # ── Ingest new results ──
            judge.ingest_results(self._results_queue)

            # ── Judge completed tasks ──
            for tid in list(judge.pending_tasks):
                if judge.ready_to_judge(tid):
                    answer, meta = judge.judge(tid)
                    judged_count += 1
                    logger.info(
                        "[pool] Judged %s: strategy=%s votes=%d largest=%d answer=%.60s",
                        tid, meta["strategy"], meta["votes_cast"],
                        meta["largest_group"], answer,
                    )

            # ── Deadline adaptation ──
            if remaining <= 0:
                logger.warning("[pool] Deadline reached — force-judging %d pending tasks",
                               len(judge.pending_tasks))
                for tid in judge.pending_tasks:
                    judge.judge(tid)
                break

            if remaining <= 60 and judge.pending_tasks:
                # <60s: force-judge any task with at least 1 answer
                for tid in list(judge.pending_tasks):
                    if judge.count_answers(tid) >= 1:
                        answer, meta = judge.judge(tid)
                        judge_quota = self.config.judgment_votes
                        logger.info(
                            "[pool] Deadline-forced %s (had %d/%d votes) → %.60s",
                            tid, meta["votes_cast"], judge_quota, answer,
                        )

            # ── Check if all tasks judged ──
            if judge.total_judged >= total_tasks:
                logger.info("[pool] All %d tasks judged", total_tasks)
                break

            # ── Busy flag cleanup: reset stale flags for dead workers (R6) ──
            for i, flag in enumerate(self._busy_flags):
                if flag.value and not self._processes[i].is_alive():
                    flag.value = 0
                    logger.warning("[pool] Reset stale busy flag for %s", self._worker_ids[i])

            # ── Brief sleep to avoid busy-waiting ──
            time.sleep(0.1)

        # ── Final drain: ingest any remaining results and judge partial tasks (R4) ──
        judge.ingest_results(self._results_queue)
        for tid in list(judge.pending_tasks):
            if judge.count_answers(tid) >= 1:
                judge.judge(tid)

    def shutdown(self, timeout: float = 5.0) -> None:
        """Gracefully terminate all worker processes."""
        self._running.clear()
        for p in self._processes:
            if p.is_alive():
                p.terminate()
        for p in self._processes:
            p.join(timeout=timeout)
            if p.is_alive():
                logger.warning("[pool] Worker %s (pid=%d) did not exit — killing", p.name, p.pid)
                p.kill()
                p.join(1.0)
        self._processes.clear()
        logger.info("[pool] All workers shut down")

    # ── Internals ──

    def _check_worker_health(self) -> list[str]:
        """Check for crashed workers. Returns list of orphaned task IDs."""
        orphaned = []
        for i, p in enumerate(self._processes):
            if not p.is_alive() and p.exitcode is not None and p.exitcode != 0:
                wid = self._worker_ids[i]
                logger.warning("[pool] Worker %s (pid=%d) died with exit code %d",
                               wid, p.pid, p.exitcode)
                if i < len(self._busy_flags):
                    self._busy_flags[i].value = 0  # Reset flag
                # We could re-dispatch its task here, but we track via
                # pending_dispatched and let the deadline drain handle it.
        return orphaned

    def _build_worker_plan(self) -> list[tuple[str, str, type, int]]:
        """Build the list of workers to start.

        Returns [(worker_id, worker_type, worker_class, worker_index), ...]
        """
        plan = []

        # Deterministic workers
        try:
            from staging.workers.det_worker import DetWorker
            register_worker_type("deterministic", DetWorker)
            for i in range(self.config.det_workers):
                plan.append((f"det_worker_{i}", "deterministic", DetWorker, i))
        except ImportError as e:
            logger.warning("DetWorker not available: %s", e)

        # Local workers
        try:
            from staging.workers.loc_worker import LocWorker
            register_worker_type("local", LocWorker)
            for i in range(self.config.loc_workers):
                plan.append((f"loc_worker_{i}", "local", LocWorker, i))
        except ImportError as e:
            logger.warning("LocWorker not available: %s", e)

        # Fireworks workers
        try:
            from staging.workers.fw_worker import FwWorker
            register_worker_type("fireworks", FwWorker)
            for i in range(self.config.fw_workers):
                plan.append((f"fw_worker_{i}", "fireworks", FwWorker, i))
        except ImportError as e:
            logger.warning("FwWorker not available: %s", e)

        logger.info("[pool] Worker plan: %d workers total (%s)",
                    len(plan), ", ".join(f"{wid}" for wid, _, _, _ in plan))
        return plan

    def _build_whitelist(self, worker_type: str) -> list[str]:
        """Return categories sorted by priority for this worker type.

        Uses the category_priority matrix from config. A lower index in
        the preference list means higher priority for that worker type.
        Categories not mentioning this worker type get priority 999.
        """
        priority_map = self.config.category_priority
        scores: dict[str, int] = {}
        for cat, pref_list in priority_map.items():
            try:
                idx = pref_list.index(worker_type)
                scores[cat] = idx
            except ValueError:
                scores[cat] = 999
        return sorted(scores, key=scores.get)

    def _enqueue_remaining(self, queue: ReadyQueue) -> None:
        """Enqueue any remaining tasks that weren't dispatched yet.
        
        Tasks go into per-worker private queues (fair round-robin distribution).
        """
        fresh = []
        while not queue.empty:
            task = queue.dequeue_any(preferred_categories=[])
            if task is None:
                break
            if task.task_id not in self._pending_dispatched:
                fresh.append(task)
                self._pending_dispatched.add(task.task_id)
        if fresh and self._worker_task_queues:
            for i, task in enumerate(fresh):
                self._worker_task_queues[i % len(self._worker_task_queues)].put_nowait(task)
            logger.info("[pool] Enqueued %d additional tasks", len(fresh))

    @property
    def busy_workers(self) -> list[str]:
        return [wid for wid, flag in zip(self._worker_ids, self._busy_flags) if flag.value]

    @property
    def available_count(self) -> int:
        return sum(1 for f in self._busy_flags if not f.value)

    @property
    def total_workers(self) -> int:
        return len(self._processes)
